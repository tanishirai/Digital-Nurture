<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!--
        Bean definition for BookRepository.
        Spring will create one instance of this class and manage it.
        id = the name used to look it up from the ApplicationContext.
        class = the fully qualified class name Spring needs to instantiate.
    -->
    <bean id="bookRepository" class="com.library.repository.BookRepository" />

    <!--
        Bean definition for BookService.
        BookService depends on BookRepository, so we inject it using a
        constructor-arg referencing the bookRepository bean above.
        This is called Dependency Injection (DI) - Spring wires the two beans together.
    -->
    <bean id="bookService" class="com.library.service.BookService">
        <constructor-arg ref="bookRepository" />
    </bean>

</beans>
